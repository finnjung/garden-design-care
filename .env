# Cloudflare Turnstile Configuration
# Fügen Sie hier Ihre Turnstile API-Keys ein

# Sitekey (öffentlich, wird im HTML-Code verwendet)
TURNSTILE_SITE_KEY=0x4AAAAAABu82HrkMXaH71_C

# Secret Key (privat, nur für Server-Side Validierung)
TURNSTILE_SECRET_KEY=0x4AAAAAABu82O3g3D17FbD2uw0UU0qoxPE

# Turnstile Verify URL (Standard URL von Cloudflare)
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# E-Mail Konfiguration (falls noch nicht vorhanden)
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_email@domain.com
SMTP_PASS=your_email_password
SMTP_FROM=info@gardendesignundcare.de
SMTP_TO=info@gardendesignundcare.de